---
interface BlogItem {
  id: string;
  title: string;
  date: Date;
  author?: string;
  href: string;
  tags?: string[];
}

interface Props {
  items: BlogItem[];
}

const { items } = Astro.props;
---

<div class="space-y-3">
  {items.map((item) => (
    <a
      href={item.href}
      class="block group p-4 bg-white rounded-lg hover:bg-indigo-50 border border-gray-200 hover:border-indigo-300 transition-all"
    >
      <div class="flex items-center justify-between mb-2">
        <h4 class="text-gray-900 font-semibold group-hover:text-indigo-600 transition-colors line-clamp-2 flex-1">
          {item.title}
        </h4>
        <span class="text-gray-400 group-hover:text-indigo-600 flex-shrink-0 ml-2">→</span>
      </div>
      
      {/* Meta Information */}
      <div class="flex items-center gap-3 text-xs text-gray-500">
        <span>{item.date.toLocaleDateString("zh-CN")}</span>
        {item.author && <span>·</span>}
        {item.author && <span>{item.author}</span>}
        {item.tags && item.tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex gap-1">
              {item.tags.slice(0, 1).map((tag) => (
                <span class="px-2 py-0 bg-indigo-100 text-indigo-700 rounded text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
    </a>
  ))}
</div>
