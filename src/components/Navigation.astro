---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const normalizePath = (path: string) => {
  if (!path) return "/";
  return path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path;
};

const normalizedCurrentPath = normalizePath(currentPath);

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  if (normalizedHref === "/") return normalizedCurrentPath === "/";
  return (
    normalizedCurrentPath === normalizedHref ||
    normalizedCurrentPath.startsWith(`${normalizedHref}/`)
  );
};
---

<header class="bg-white shadow fixed top-0 left-0 right-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-20">
      {/* Combined Logo */}
      <a href="/" class="flex items-center min-w-0">
        <img
          src="/combined-logo.png"
          alt="Waymaker 与交叉创新中心联合 Logo"
          class="h-12 sm:h-16 w-auto max-w-[230px] sm:max-w-[460px] object-contain"
          loading="eager"
        />
      </a>

      {/* Navigation Menu */}
      <nav class="hidden sm:flex gap-8">
        <a
          href="/"
          class={`text-sm font-medium transition-colors ${
            isActive("/")
              ? "text-indigo-600 border-b-2 border-indigo-600"
              : "text-gray-600 hover:text-gray-900"
          }`}
        >
          首页
        </a>
        <a
          href="/members"
          class={`text-sm font-medium transition-colors ${
            isActive("/members")
              ? "text-indigo-600 border-b-2 border-indigo-600"
              : "text-gray-600 hover:text-gray-900"
          }`}
        >
          成员
        </a>
        <a
          href="/blogs"
          class={`text-sm font-medium transition-colors ${
            isActive("/blogs")
              ? "text-indigo-600 border-b-2 border-indigo-600"
              : "text-gray-600 hover:text-gray-900"
          }`}
        >
          博客
        </a>
        <a
          href="/news"
          class={`text-sm font-medium transition-colors ${
            isActive("/news")
              ? "text-indigo-600 border-b-2 border-indigo-600"
              : "text-gray-600 hover:text-gray-900"
          }`}
        >
          新闻
        </a>
      </nav>

      {/* Mobile Menu Button */}
      <button class="sm:hidden p-2 text-gray-600 hover:text-gray-900">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>
</header>
