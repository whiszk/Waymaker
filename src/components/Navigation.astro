---
export interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

const normalizePath = (path: string) => {
  if (!path) return "/";
  return path !== "/" && path.endsWith("/") ? path.slice(0, -1) : path;
};

const normalizedCurrentPath = normalizePath(currentPath);

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  if (normalizedHref === "/") return normalizedCurrentPath === "/";
  return (
    normalizedCurrentPath === normalizedHref ||
    normalizedCurrentPath.startsWith(`${normalizedHref}/`)
  );
};
---

<header class="bg-white shadow fixed top-0 left-0 right-0 z-40">
  <div class="max-w-7xl mx-auto px-8">
    <div class="flex justify-between items-center h-20">
      {/* Combined Logo */}
      <a href="/" class="flex items-center min-w-0 gap-6">
        <img
          src="/combined-logo.png"
          alt="Waymaker 与交叉创新中心联合 Logo"
          class="h-14 w-auto max-w-[340px] object-contain"
          loading="eager"
        />
        <span
          class="text-[24px] font-black tracking-[0em] text-black leading-tight whitespace-nowrap font-['PingFang_SC','Helvetica_Neue','Microsoft_YaHei','sans-serif']"
        >
          重庆大学 Waymaker 智能基座社团
        </span>
      </a>

      {/* Navigation Menu */}
      <nav class="flex gap-8">
        <a
          href="/"
          class={`text-sm font-medium transition-colors ${
            isActive("/")
              ? "text-[#022F66] border-b-2 border-[#05C9C9]"
              : "text-gray-600 hover:text-[#022F66]"
          }`}
        >
          首页
        </a>
        <a
          href="/news"
          class={`text-sm font-medium transition-colors ${
            isActive("/news")
              ? "text-[#022F66] border-b-2 border-[#05C9C9]"
              : "text-gray-600 hover:text-[#022F66]"
          }`}
        >
          新闻
        </a>

        <a
          href="/blogs"
          class={`text-sm font-medium transition-colors ${
            isActive("/blogs")
              ? "text-[#022F66] border-b-2 border-[#05C9C9]"
              : "text-gray-600 hover:text-[#022F66]"
          }`}
        >
          博客
        </a>
        <a
          href="/members"
          class={`text-sm font-medium transition-colors ${
            isActive("/members")
              ? "text-[#022F66] border-b-2 border-[#05C9C9]"
              : "text-gray-600 hover:text-[#022F66]"
          }`}
        >
          成员
        </a>
        <a
          href="/recruitment"
          class={`text-sm font-medium transition-colors ${
            isActive("/recruitment")
              ? "text-[#022F66] border-b-2 border-[#05C9C9]"
              : "text-gray-600 hover:text-[#022F66]"
          }`}
        >
          加入我们
        </a>
      </nav>
    </div>
  </div>
</header>
