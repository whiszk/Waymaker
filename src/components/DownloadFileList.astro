---
interface FileItem {
    title: string;
    href: string;
}

interface Props {
    title?: string;
    description?: string;
    helperText?: string;
    items: FileItem[];
}

const { title = "资料下载", description, helperText, items } = Astro.props;

const getFileExtension = (href: string) => {
    const normalizedHref = href.split("?")[0].split("#")[0];
    const fileName = normalizedHref.split("/").pop() ?? "";
    const dotIndex = fileName.lastIndexOf(".");

    if (dotIndex <= 0 || dotIndex === fileName.length - 1) {
        return "";
    }

    return fileName.slice(dotIndex).toLowerCase();
};
---

<section class="bg-white rounded-xl border border-[#D5EEEE] p-6 shadow-sm">
    <h2 class="text-2xl font-bold text-[#022F66]">{title}</h2>
    {
        description && (
            <p class="mt-2 text-[#475569] text-sm leading-6">{description}</p>
        )
    }
    {
        helperText && (
            <p class="mt-4 px-3 py-2 rounded-lg bg-[#E6FAFA] text-[#028A8A] text-sm font-semibold">
                {helperText}
            </p>
        )
    }

    <div class="mt-4 divide-y divide-[#E2E8F0]">
        {
            items.map((item) => {
                const extension = getFileExtension(item.href);

                return (
                    <a
                        href={item.href}
                        download
                        class="flex items-center py-3 text-base font-semibold text-[#022F66] transition-colors hover:text-[#03A8A8]"
                    >
                        <span class="truncate">
                            {item.title}
                            {extension && (
                                <span class="ml-1 text-sm font-medium text-[#64748B]">
                                    {extension}
                                </span>
                            )}
                        </span>
                    </a>
                );
            })
        }
    </div>
</section>
