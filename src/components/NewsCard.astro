---
interface Props {
  title: string;
  description?: string;
  date: Date;
  cover?: string;
  href: string;
}

const { title, description, date, cover, href } = Astro.props;
---

<a
  href={href}
  class="group block h-full bg-white rounded-xl shadow-md hover:shadow-xl overflow-hidden transition-all duration-300 hover:scale-105"
>
  {/* Image Container */}
  {cover && (
    <div class="relative h-48 overflow-hidden bg-gray-200">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
      />
      {/* Date Badge */}
      <div class="absolute top-4 right-4 bg-indigo-600 text-white px-3 py-1 rounded-full text-xs font-semibold">
        {date.toLocaleDateString("zh-CN")}
      </div>
    </div>
  )}

  {/* Content Container */}
  <div class={`p-6 ${cover ? '' : 'h-48 flex flex-col justify-between'}`}>
    <div>
      <h3 class="text-lg font-bold text-gray-900 line-clamp-2 mb-2 group-hover:text-indigo-600 transition-colors">
        {title}
      </h3>
      {description && (
        <p class="text-gray-600 text-sm line-clamp-2">
          {description}
        </p>
      )}
    </div>

    {/* Footer */}
    <div class="mt-4 pt-4 border-t border-gray-100 flex items-center justify-between">
      <span class="text-xs text-indigo-600 font-semibold">查看详情</span>
      <span class="text-gray-400 group-hover:text-indigo-600 transition-colors">→</span>
    </div>
  </div>
</a>
