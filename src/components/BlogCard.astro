---
interface Props {
  title: string;
  description?: string;
  date: Date;
  cover?: string;
  author?: string;
  href: string;
  tags?: string[];
}

const { title, description, date, cover, author, href, tags = [] } = Astro.props;
---

<a
  href={href}
  class="group block h-full bg-white rounded-xl shadow-md hover:shadow-xl overflow-hidden transition-all duration-300 hover:scale-105"
>
  {/* Image Container */}
  {cover && (
    <div class="relative h-48 overflow-hidden bg-gray-200">
      <img
        src={cover}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-300"
      />
    </div>
  )}

  {/* Content Container */}
  <div class={`p-6 flex flex-col ${cover ? '' : 'justify-between'}`} style={!cover ? 'height: 12rem;' : ''}>
    <div>
      {/* Tags */}
      {tags.length > 0 && (
        <div class="mb-3 flex flex-wrap gap-2">
          {tags.slice(0, 2).map((tag) => (
            <span class="inline-block px-2 py-1 text-xs font-medium bg-indigo-100 text-indigo-700 rounded-full">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h3 class="text-lg font-bold text-gray-900 line-clamp-2 mb-2 group-hover:text-indigo-600 transition-colors">
        {title}
      </h3>
      {description && (
        <p class="text-gray-600 text-sm line-clamp-2">
          {description}
        </p>
      )}
    </div>

    {/* Meta Info */}
    <div class="mt-4 pt-4 border-t border-gray-100">
      <div class="flex items-center justify-between text-xs text-gray-500">
        <div class="flex items-center gap-4">
          <span>{date.toLocaleDateString("zh-CN")}</span>
          {author && <span>by {author}</span>}
        </div>
        <span class="text-gray-400 group-hover:text-indigo-600 transition-colors">→</span>
      </div>
    </div>
  </div>
</a>
