---
interface Props {
  items: Array<{
    id: string;
    title: string;
    date: Date;
    cover?: string;
    description?: string;
    href: string;
  }>;
}

const { items } = Astro.props;
---

<div class="space-y-6">
  {/* Carousel Section */}
  <div class="relative rounded-xl overflow-hidden bg-gray-900 h-96">
    <div
      class="splide featured-carousel"
      data-splide='{"type": "fade", "rewind": true, "autoplay": true, "interval": 5000, "pauseOnHover": true}'
    >
      <div class="splide__track h-96">
        <ul class="splide__list">
          {
            items.map((item) => (
              <li class="splide__slide relative h-96">
                <a href={item.href} class="block relative h-96 cursor-pointer">
                  {/* Background Image */}
                  {item.cover && (
                    <img
                      src={item.cover}
                      alt={item.title}
                      class="absolute inset-0 w-full h-full object-cover"
                    />
                  )}

                  {/* Overlay Gradient */}
                  <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent" />

                  {/* Content at Bottom */}
                  <div class="absolute bottom-0 left-0 right-0 p-6">
                    <h3 class="text-3xl font-bold text-white line-clamp-2">
                      {item.title}
                    </h3>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Navigation */}
      <div
        class="splide__arrows absolute inset-y-0 left-0 right-0 flex items-center justify-between px-4 z-20 pointer-events-none"
      >
        <button
          class="splide__arrow splide__arrow--prev pointer-events-auto w-11 h-11 bg-white/35 hover:bg-white/55 text-white rounded-full flex items-center justify-center transition-colors"
        >
          ←
        </button>
        <button
          class="splide__arrow splide__arrow--next pointer-events-auto w-11 h-11 bg-white/35 hover:bg-white/55 text-white rounded-full flex items-center justify-center transition-colors"
        >
          →
        </button>
      </div>

      {/* Dots */}
      <div class="splide__pagination absolute bottom-4 left-4 flex gap-2"></div>
    </div>
  </div>

  {/* Links Section */}
  <div class="space-y-3">
    {
      items.map((item) => (
        <a
          href={item.href}
          class="block group p-4 bg-white rounded-lg hover:bg-[#E6FAFA] border border-gray-200 hover:border-[#9FE5E5] transition-all"
        >
          <div class="flex items-center justify-between gap-3">
            <h4 class="text-gray-900 font-semibold group-hover:text-[#022F66] transition-colors line-clamp-1 min-w-0 flex-1">
              {item.title}
            </h4>
            <div class="flex items-center flex-shrink-0 ml-2">
              <span class="text-xs font-medium text-gray-500">
                {item.date.toLocaleDateString("zh-CN")}
              </span>
            </div>
          </div>
        </a>
      ))
    }
  </div>
</div>

<style>
  :global(.featured-carousel .splide__pagination__page.is-active) {
    background: rgba(255, 255, 255, 0.9);
  }

  :global(.featured-carousel .splide__pagination__page) {
    background: rgba(255, 255, 255, 0.4);
    width: 10px;
    height: 10px;
    border-radius: 50%;
    margin: 0 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  :global(.featured-carousel .splide__pagination__page:hover) {
    background: rgba(255, 255, 255, 0.7);
  }
</style>

<script>
  import Splide from "@splidejs/splide";

  document.addEventListener("DOMContentLoaded", () => {
    const carousel = document.querySelector(
      ".featured-carousel",
    ) as HTMLElement;
    if (carousel && !(carousel as any).splide) {
      new Splide(carousel, {
        type: "fade",
        rewind: true,
        autoplay: true,
        interval: 5000,
        pauseOnHover: true,
        speed: 600,
      }).mount();
    }
  });
</script>
