---
interface Props {
  items: Array<{
    id: string;
    title: string;
    cover?: string;
    description?: string;
  }>;
}

const { items } = Astro.props;
---

<div class="relative h-[500px] overflow-hidden bg-gray-900">
  <div class="splide hero-carousel" data-splide='{"type": "fade", "rewind": true, "autoplay": true, "interval": 5000, "pauseOnHover": true}'>
    <div class="splide__track">
      <ul class="splide__list">
        {items.map((item) => (
          <li class="splide__slide relative">
            {/* Background Image */}
            {item.cover && (
              <img
                src={item.cover}
                alt={item.title}
                class="absolute inset-0 w-full h-full object-cover"
              />
            )}
            
            {/* Overlay Gradient */}
            <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/50 to-transparent"></div>
            
            {/* Content */}
            <div class="absolute inset-0 flex items-center">
              <div class="max-w-3xl px-6 sm:px-12">
                <h2 class="text-4xl sm:text-5xl md:text-6xl font-bold text-white mb-4 line-clamp-3">
                  {item.title}
                </h2>
                {item.description && (
                  <p class="text-lg sm:text-xl text-gray-200 mb-6 line-clamp-2">
                    {item.description}
                  </p>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
    
    {/* Navigation Arrows */}
    <div class="splide__arrows absolute bottom-6 left-6 flex gap-2 z-20">
      <button class="splide__arrow splide__arrow--prev w-12 h-12 bg-white/20 hover:bg-white/40 text-white rounded-full flex items-center justify-center transition-colors" aria-label="Previous slide">
        ←
      </button>
      <button class="splide__arrow splide__arrow--next w-12 h-12 bg-white/20 hover:bg-white/40 text-white rounded-full flex items-center justify-center transition-colors" aria-label="Next slide">
        →
      </button>
    </div>

    {/* Dots */}
    <div class="splide__pagination absolute bottom-6 right-6 flex gap-2"></div>
  </div>
</div>

<style>
  :global(.hero-carousel .splide__pagination__page.is-active) {
    background: white;
  }

  :global(.hero-carousel .splide__pagination__page) {
    background: rgba(255, 255, 255, 0.5);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    margin: 4px;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  :global(.hero-carousel .splide__pagination__page:hover) {
    background: rgba(255, 255, 255, 0.8);
  }
</style>

<script>
  import Splide from '@splidejs/splide';
  
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.querySelector('.hero-carousel') as HTMLElement;
    if (carousel && !(carousel as any).splide) {
      new Splide(carousel, {
        type: 'fade',
        rewind: true,
        autoplay: true,
        interval: 5000,
        pauseOnHover: true,
        speed: 600,
      }).mount();
    }
  });
</script>
