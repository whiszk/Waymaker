---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Waymaker 成员认证">
  <div class="min-h-screen bg-[#f7f4fa]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <aside class="lg:col-span-3">
          <div class="bg-white/80 rounded-xl border border-purple-100 p-6 shadow-sm">
            <div class="space-y-4 text-lg">
              <div>
                <a
                  href="/recruitment"
                  class="block px-4 py-2 rounded-lg text-2xl font-bold text-gray-500 hover:text-purple-700 hover:bg-purple-50 transition-colors"
                >
                  纳新
                </a>
                <ul class="mt-3 ml-3 pl-4 border-l border-purple-200 space-y-2">
                  <li>
                    <a
                      href="/recruitment"
                      class="block px-3 py-2 rounded-lg text-gray-500 hover:text-purple-700 hover:bg-purple-50 transition-colors"
                    >
                      通知公告
                    </a>
                  </li>
                  <li>
                    <a
                      href="/recruitment-qq"
                      class="block px-3 py-2 rounded-lg text-gray-500 hover:text-purple-700 hover:bg-purple-50 transition-colors"
                    >
                      社团官Q
                    </a>
                  </li>
                </ul>
              </div>

              <div>
                <span class="block px-4 py-2 rounded-lg bg-purple-100 text-purple-800 text-2xl font-bold">
                  成员认证
                </span>
              </div>
            </div>
          </div>
        </aside>

        <section class="lg:col-span-9 bg-white rounded-xl border border-purple-100 p-8 shadow-sm relative overflow-hidden">
          <div class="absolute right-0 top-0 w-64 h-64 bg-purple-50 rounded-full -translate-y-20 translate-x-20"></div>
          <div class="relative">
            <h1 class="text-5xl font-extrabold text-purple-700 tracking-wide">成员认证</h1>
            <div class="mt-3 h-1 w-28 bg-purple-600 rounded"></div>

            <p class="mt-10 text-xl text-gray-700 leading-9">
              点击跳转智能基座社团-鲲鹏&昇腾教育科研平台
              <a
                href="https://www.bing.com/ck/a?!&&p=393abdaf54d411231ec34600d6185bd9e3fb71dec5ba40d4590a3e948feb6d8dJmltdHM9MTc3NDY1NjAwMA&ptn=3&ver=2&hsh=4&fclid=0d032379-1b77-6f8f-246e-35611aa56e5b&psq=%e5%8d%8e%e4%b8%ba%e6%99%ba%e8%83%bd%e5%9f%ba%e5%ba%a7&u=a1aHR0cHM6Ly9lZHUuaGljb21wdXRpbmcuaHVhd2VpLmNvbS9BSWVkdWNhdGlvbmJhc2U"
                target="_blank"
                rel="noreferrer"
                class="text-purple-700 hover:text-purple-900 underline font-semibold"
              >
                https://www.bing.com/ck/a?!&&p=393abdaf54d411231ec34600d6185bd9e3fb71dec5ba40d4590a3e948feb6d8dJmltdHM9MTc3NDY1NjAwMA&ptn=3&ver=2&hsh=4&fclid=0d032379-1b77-6f8f-246e-35611aa56e5b&psq=%e5%8d%8e%e4%b8%ba%e6%99%ba%e8%83%bd%e5%9f%ba%e5%ba%a7&u=a1aHR0cHM6Ly9lZHUuaGljb21wdXRpbmcuaHVhd2VpLmNvbS9BSWVkdWNhdGlvbmJhc2U
              </a>
              进行成员认证。
            </p>

            <div class="mt-10 flex items-center gap-6">
              <a href="/" class="text-purple-700 hover:text-purple-900 font-semibold">返回首页</a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
