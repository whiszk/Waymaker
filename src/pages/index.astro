---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import NewsFeaturedCarousel from "../components/NewsFeaturedCarousel.astro";
import BlogLinks from "../components/BlogLinks.astro";
import { assertUniqueBlogSlugs, getBlogSlug } from "../utils/blog";

const allNews = await getCollection("news");
const allBlogs = await getCollection("blogs");

const getCoverSrc = (cover: string | { src: string } | undefined) =>
  typeof cover === "string" ? cover : cover?.src;

// Sort by date descending
const sortedNews = allNews.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const sortedBlogs = allBlogs.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
assertUniqueBlogSlugs(sortedBlogs);

// For news featured section: latest 6 news
const featuredNews = sortedNews.slice(0, 6).map((item) => ({
  id: item.id,
  title: item.data.title,
  date: item.data.date,
  cover: getCoverSrc(item.data.cover),
  description: item.data.description,
  href: `/news/${item.id}`,
}));

// For blog links: latest 6 blogs
const blogItems = sortedBlogs.slice(0, 6).map((item) => ({
  id: item.id,
  title: item.data.title,
  date: item.data.date,
  author: item.data.author,
  href: `/blogs/${getBlogSlug(item)}`,
  tags: item.data.tags,
}));
---

<Layout title="Waymaker 智能基座社团 - 首页">
  <div
    class="relative overflow-hidden bg-gradient-to-b from-[#F1FBFB] via-[#F7FBFF] to-[#EEF4FA]"
  >
    <div
      class="pointer-events-none absolute inset-0 [background:radial-gradient(ellipse_at_top_right,rgba(5,201,201,0.12),transparent_45%),radial-gradient(ellipse_at_bottom_left,rgba(2,47,102,0.10),transparent_45%)]"
    >
    </div>
    <div
      class="pointer-events-none absolute -top-24 -left-24 h-[24rem] w-[24rem] rounded-full bg-[#CDEFF1] opacity-82 blur-[118px]"
    >
    </div>
    <div
      class="pointer-events-none absolute top-[18%] right-[-90px] h-[22rem] w-[22rem] rounded-full bg-[#D4E5FA] opacity-78 blur-[102px]"
    >
    </div>
    <div
      class="pointer-events-none absolute top-[44%] left-[8%] h-72 w-72 rounded-full bg-[#D8DDE7] opacity-60 blur-[92px]"
    >
    </div>
    <div
      class="pointer-events-none absolute bottom-[10%] right-[16%] h-80 w-80 rounded-full bg-[#D2EEF0] opacity-76 blur-[106px]"
    >
    </div>
    <div
      class="pointer-events-none absolute -bottom-24 left-[34%] h-[23rem] w-[23rem] rounded-full bg-[#CED8E2] opacity-54 blur-[112px]"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-8 py-14 space-y-14">
      <section
        class="relative rounded-2xl border border-[#D5EEEE] bg-white p-10 overflow-hidden shadow-[0_18px_45px_rgba(2,47,102,0.08)]"
      >
        <div
          class="absolute -top-24 -right-20 w-72 h-72 rounded-full bg-[#E6FAFA]"
        >
        </div>
        <div
          class="absolute -bottom-20 -left-16 w-64 h-64 rounded-full bg-[#E9EEF6]"
        >
        </div>

        <div class="relative">
          <div class="text-center">
            <h2 class="text-4xl font-extrabold text-[#022F66]">最新动态</h2>
            <p class="mt-4 text-lg text-[#475569]">
              聚焦社团新闻、赛事通知与技术活动现场
            </p>
            <div class="mt-4 w-60 h-1 bg-[#05C9C9] rounded mx-auto"></div>
          </div>

          <div class="mt-10 max-w-5xl mx-auto">
            {
              featuredNews.length > 0 ? (
                <NewsFeaturedCarousel items={featuredNews} />
              ) : (
                <div class="text-center py-16 bg-gray-100 rounded-lg">
                  <p class="text-gray-500">暂无最新动态</p>
                </div>
              )
            }
          </div>
        </div>
      </section>

      <section
        class="bg-white rounded-2xl border border-[#D5EEEE] p-8 shadow-[0_14px_38px_rgba(2,47,102,0.07)]"
      >
        <div class="text-center mb-6">
          <h2 class="text-3xl font-bold text-[#022F66]">常用入口</h2>
        </div>
        <div class="grid grid-cols-4 gap-4">
          <a
            href="/news"
            class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-white text-[#022F66] border border-[#022F66] rounded-lg hover:bg-[#E6FAFA] transition-colors font-semibold"
          >
            查看全部动态 <span>→</span>
          </a>
          <a
            href="/blogs"
            class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-white text-[#022F66] border border-[#022F66] rounded-lg hover:bg-[#E6FAFA] transition-colors font-semibold"
          >
            查看全部博客 <span>→</span>
          </a>
          <a
            href="/members"
            class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-white text-[#022F66] border border-[#022F66] rounded-lg hover:bg-[#E6FAFA] transition-colors font-semibold"
          >
            成员风采 <span>→</span>
          </a>
          <a
            href="/recruitment"
            class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-[#05C9C9] text-white rounded-lg hover:bg-[#03A8A8] transition-colors font-semibold"
          >
            加入我们 <span>→</span>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>
