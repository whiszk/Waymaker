---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import NewsFeaturedCarousel from "../components/NewsFeaturedCarousel.astro";
import BlogLinks from "../components/BlogLinks.astro";
import { assertUniqueBlogSlugs, getBlogSlug } from "../utils/blog";

const allNews = await getCollection("news");
const allBlogs = await getCollection("blogs");

const getCoverSrc = (cover: string | { src: string } | undefined) =>
  typeof cover === "string" ? cover : cover?.src;

// Sort by date descending
const sortedNews = allNews.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const sortedBlogs = allBlogs.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
assertUniqueBlogSlugs(sortedBlogs);

// For news featured section: latest 6 news
const featuredNews = sortedNews.slice(0, 6).map((item) => ({
  id: item.id,
  title: item.data.title,
  date: item.data.date,
  cover: getCoverSrc(item.data.cover),
  description: item.data.description,
  href: `/news/${item.id}`,
}));

// For blog links: latest 6 blogs
const blogItems = sortedBlogs.slice(0, 6).map((item) => ({
  id: item.id,
  title: item.data.title,
  date: item.data.date,
  author: item.data.author,
  href: `/blogs/${getBlogSlug(item)}`,
  tags: item.data.tags,
}));
---

<Layout title="Waymaker 智能基座社团 - 首页">
  <div
    class="relative overflow-hidden bg-gradient-to-b from-[#F1FBFB] via-[#F7FBFF] to-[#EEF4FA]"
  >
    <div
      class="pointer-events-none absolute inset-0 [background:radial-gradient(ellipse_at_top_right,rgba(5,201,201,0.12),transparent_45%),radial-gradient(ellipse_at_bottom_left,rgba(2,47,102,0.10),transparent_45%)]"
    >
    </div>
    <div class="relative max-w-7xl mx-auto px-8 py-14 space-y-14">
      <section
        class="relative rounded-2xl border border-[#D5EEEE] bg-white p-10 overflow-hidden shadow-[0_18px_45px_rgba(2,47,102,0.08)]"
      >
        <div
          class="absolute -top-24 -right-20 w-72 h-72 rounded-full bg-[#E6FAFA]"
        >
        </div>
        <div
          class="absolute -bottom-20 -left-16 w-64 h-64 rounded-full bg-[#E9EEF6]"
        >
        </div>

        <div class="relative">
          <div class="text-center">
            <h2 class="text-4xl font-extrabold text-[#022F66]">最新动态</h2>
            <p class="mt-4 text-lg text-[#475569]">
              聚焦社团新闻、赛事通知与技术活动现场。
            </p>
            <div class="mt-4 w-20 h-1 bg-[#05C9C9] rounded mx-auto"></div>
          </div>

          <div class="mt-10 max-w-5xl mx-auto">
            {
              featuredNews.length > 0 ? (
                <NewsFeaturedCarousel items={featuredNews} />
              ) : (
                <div class="text-center py-16 bg-gray-100 rounded-lg">
                  <p class="text-gray-500">暂无最新动态</p>
                </div>
              )
            }
          </div>
        </div>
      </section>

      <section
        class="bg-white rounded-2xl border border-[#D5EEEE] p-10 shadow-[0_14px_38px_rgba(2,47,102,0.07)]"
      >
        <div class="mb-8 border-b border-[#D5EEEE] pb-6">
          <h2 class="text-4xl font-extrabold text-[#022F66]">技术博客</h2>
          <p class="mt-4 text-xl text-[#475569]">
            成员们的学习心得、技术分享与项目总结。
          </p>
        </div>

        {
          blogItems.length > 0 ? (
            <BlogLinks items={blogItems} />
          ) : (
            <div class="text-center py-12 bg-gray-100 rounded-lg">
              <p class="text-gray-500">暂无博客文章</p>
            </div>
          )
        }
      </section>
    </div>
  </div>
</Layout>
