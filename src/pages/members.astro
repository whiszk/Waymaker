---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const members = await getCollection("members");
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
      <div class="mb-10">
        <h1 class="text-4xl font-extrabold text-gray-900">优秀成员风采</h1>
        <p class="mt-4 text-xl text-gray-500">认识我们最骄傲的核心骨干力量。</p>
      </div>

      <div class="space-y-8">
        {
          members.map((member) => (
            <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
              <h2 class="text-2xl font-bold text-gray-900 mb-2">{member.data.name}</h2>
              <p class="text-indigo-600 font-medium mb-4">{member.data.role}</p>
              <p class="text-gray-600 leading-7">{member.data.bio}</p>
            </article>
          ))
        }
      </div>

      <div class="mt-12">
        <a href="/" class="text-indigo-600 hover:text-indigo-500 font-medium"
          >← 返回首页</a
        >
      </div>
    </div>
  </div>
</Layout>
