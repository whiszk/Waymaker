---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const members = await getCollection("members");
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 flex flex-col">
    <div class="max-w-7xl mx-auto w-full flex-grow">
      <div class="text-center mb-12">
        <h1
          class="text-3xl font-extrabold text-gray-900 sm:text-4xl hover:text-indigo-600 transition-colors"
        >
          优秀成员风采
        </h1>
        <p class="mt-4 text-xl text-gray-500">认识我们最骄傲的核心骨干力量。</p>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          members.map((member) => (
            <div class="bg-white overflow-hidden shadow rounded-lg p-6">
              <h3 class="text-xl font-bold text-gray-900">
                {member.data.name}
              </h3>
              <p class="text-sm text-indigo-600 font-medium mt-1">
                {member.data.role}
              </p>
              <p class="mt-4 text-gray-600 text-sm">{member.data.bio}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-12 text-center">
        <a
          href="/"
          class="text-indigo-600 hover:text-indigo-500 font-medium text-lg"
          >← 返回首页</a
        >
      </div>
    </div>
  </div>
</Layout>
