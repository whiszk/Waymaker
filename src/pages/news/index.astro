---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const newsItems = await getCollection("news");
newsItems.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8 flex flex-col">
    <div class="max-w-5xl mx-auto w-full flex-grow flex flex-col">
      <div class="mb-10 border-b pb-6">
        <h1 class="text-4xl font-extrabold text-gray-900">
          新闻推文 & 赛事通知
        </h1>
        <p class="mt-4 text-xl text-gray-500">
          掌握社团最新动态和校园开源咨询。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 flex-grow content-start">
        {
          newsItems.map((item) => (
            <article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-lg transition-all flex flex-col">
              {item.data.cover ? (
                <a href={`/news/${item.id}`} class="block h-48 overflow-hidden">
                  <img
                    src={item.data.cover}
                    alt={item.data.title}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                  />
                </a>
              ) : (
                <div class="h-48 bg-indigo-50 flex items-center justify-center">
                  <span class="text-indigo-200 font-bold text-2xl">NEWS</span>
                </div>
              )}
              <div class="p-6 flex flex-col flex-1">
                <time class="text-xs font-semibold text-indigo-600 mb-2 uppercase tracking-wide">
                  {item.data.date.toLocaleDateString("zh-CN")}
                </time>
                <h2 class="text-xl font-bold text-gray-900 mb-3 line-clamp-2">
                  <a href={`/news/${item.id}`} class="hover:text-indigo-600">
                    {item.data.title}
                  </a>
                </h2>
                <p class="text-gray-600 text-sm mb-4 line-clamp-3 flex-1">
                  {item.data.description}
                </p>
                <div class="mt-auto pt-4 border-t border-gray-100">
                  <a
                    href={`/news/${item.id}`}
                    class="text-indigo-600 hover:text-indigo-800 text-sm font-medium flex items-center"
                  >
                    阅读全文 <span class="ml-1">→</span>
                  </a>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-12">
        <a href="/" class="text-indigo-600 hover:text-indigo-500 font-medium text-lg"
          >← 返回首页</a
        >
      </div>
    </div>
  </div>
</Layout>
