---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const newsItems = await getCollection("news");
  return newsItems.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const coverSrc =
  typeof item.data.cover === "string" ? item.data.cover : item.data.cover?.src;
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-12 px-8">
    <article class="max-w-5xl mx-auto">
      <div class="mb-10 border-b pb-6">
        <a
          href="/news"
          class="text-[#022F66] hover:text-[#011D3F] font-medium mb-6 inline-block"
          >← 返回新闻列表</a
        >
        <h1 class="text-4xl font-extrabold text-gray-900 mb-4">
          {item.data.title}
        </h1>
        <div class="text-gray-500 text-sm">
          发布日期: <time>{item.data.date.toLocaleDateString("zh-CN")}</time>
        </div>
      </div>

      {
        coverSrc && (
          <div class="mb-8">
            <img
              src={coverSrc}
              alt="Cover image"
              class="w-full h-[450px] rounded-xl shadow-sm object-cover"
            />
          </div>
        )
      }

      <div class="bg-white rounded-xl border border-[#D5EEEE] p-8 shadow-sm">
        <div
          class="prose prose-slate prose-lg max-w-none prose-img:rounded-xl prose-img:shadow-md prose-headings:text-gray-900 prose-a:text-[#022F66]"
        >
          <Content />
        </div>
      </div>

      <div class="mt-12">
        <a
          href="/"
          class="text-[#022F66] hover:text-[#011D3F] font-medium text-lg"
          >← 返回首页</a
        >
      </div>
    </article>
  </div>
</Layout>
