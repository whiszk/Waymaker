---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { assertUniqueBlogSlugs, getBlogSlug } from "../../utils/blog";

// 拿到当前的所有blog
const blogs = await getCollection("blogs");

blogs.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
assertUniqueBlogSlugs(blogs);
---

<Layout>
  <div class="min-h-screen bg-gray-50 py-12 px-8 flex flex-col">
    <div class="max-w-5xl mx-auto w-full flex-grow flex flex-col">
      <div class="mb-10 border-b pb-6">
        <h1 class="text-4xl font-extrabold text-gray-900">技术博客</h1>
        <p class="mt-4 text-xl text-gray-500">
          成员们的学习心得、技术分享与项目总结。
        </p>
      </div>

      <div class="space-y-8 flex-grow">
        {
          blogs.map((blog) => (
            <article class="bg-white p-6 rounded-lg shadow-sm border border-gray-100 flex flex-row gap-6 hover:shadow-md transition-shadow">
              {blog.data.cover && (
                <div class="w-1/3 shrink-0">
                  <img
                    src={blog.data.cover}
                    alt={blog.data.title}
                    class="w-full h-48 object-cover rounded-md"
                  />
                </div>
              )}
              <div class="flex-1 flex flex-col justify-center">
                <h2 class="text-2xl font-bold text-gray-900 mb-2">
                  <a
                    href={`/blogs/${getBlogSlug(blog)}`}
                    class="hover:text-[#022F66] transition-colors"
                  >
                    {blog.data.title}
                  </a>
                </h2>
                <p class="text-gray-600 mb-4 line-clamp-3">
                  {blog.data.description}
                </p>
                <div class="flex items-center text-sm text-gray-500 mt-auto">
                  <span class="font-medium mr-4">
                    {blog.data.author || "匿名"}
                  </span>
                  <time datetime={blog.data.date.toISOString()}>
                    {blog.data.date.toLocaleDateString("zh-CN")}
                  </time>
                </div>
              </div>
            </article>
          ))
        }
      </div>

      <div class="mt-12">
        <a href="/" class="text-[#022F66] hover:text-[#011D3F] font-medium"
          >← 返回首页</a
        >
      </div>
    </div>
  </div>
</Layout>
