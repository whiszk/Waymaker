---
import Layout from "../layouts/Layout.astro";

const notices = [
  {
    title: "重庆大学智能基座社团纳新报名表",
    date: "2026-03-28",
    href: "/docs/recruitment-form.docx",
  },
  {
    title: "智能基座协会26春季纳新说明",
    date: "2026-03-28",
    href: "/docs/recruitment-guide.docx",
  },
];
---

<Layout title="Waymaker 纳新公告">
  <div class="min-h-screen bg-[#f7f4fa]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">
        <aside class="lg:col-span-3">
          <div class="bg-white/80 rounded-xl border border-purple-100 p-6 shadow-sm">
            <div class="space-y-4 text-lg">
              <div>
                <span class="block px-4 py-2 rounded-lg bg-purple-100 text-purple-800 text-2xl font-bold">
                  纳新
                </span>
                <ul class="mt-3 ml-3 pl-4 border-l border-purple-200 space-y-2">
                  <li>
                    <span class="block px-3 py-2 rounded-lg bg-purple-100 text-purple-800 font-semibold">
                      通知公告
                    </span>
                  </li>
                  <li>
                    <a
                      href="/recruitment-qq"
                      class="block px-3 py-2 rounded-lg text-gray-500 hover:text-purple-700 hover:bg-purple-50 transition-colors"
                    >
                      社团官Q
                    </a>
                  </li>
                </ul>
              </div>

              <div>
                <a
                  href="/recruitment-auth"
                  class="block px-4 py-2 rounded-lg text-2xl font-bold text-gray-500 hover:text-purple-700 hover:bg-purple-50 transition-colors"
                >
                  成员认证
                </a>
              </div>
            </div>
          </div>
        </aside>

        <section class="lg:col-span-9 bg-white rounded-xl border border-purple-100 p-8 shadow-sm relative overflow-hidden">
          <div class="absolute right-0 top-0 w-64 h-64 bg-purple-50 rounded-full -translate-y-20 translate-x-20"></div>
          <div class="relative">
            <h1 class="text-5xl font-extrabold text-purple-700 tracking-wide">通知公告</h1>
            <div class="mt-3 h-1 w-28 bg-purple-600 rounded"></div>

            <div class="mt-12 divide-y divide-gray-200">
              {
                notices.map((item) => (
                  <a
                    href={item.href}
                    target="_blank"
                    rel="noreferrer"
                    class="flex items-center justify-between gap-4 py-7 group"
                  >
                    <div class="flex items-start gap-3 min-w-0">
                      <span class="text-2xl leading-none text-gray-800 mt-1">•</span>
                      <p class="text-xl font-semibold text-gray-900 group-hover:text-purple-700 transition-colors line-clamp-2">
                        {item.title}
                      </p>
                    </div>
                    <time class="text-3xl text-gray-500 font-light tracking-wide whitespace-nowrap">
                      {item.date}
                    </time>
                  </a>
                ))
              }
            </div>

            <div class="mt-10">
              <a href="/" class="text-purple-700 hover:text-purple-900 font-semibold">← 返回首页</a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
