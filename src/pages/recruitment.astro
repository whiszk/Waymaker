---
import Layout from "../layouts/Layout.astro";
import DownloadFileList from "../components/DownloadFileList.astro";

const authUrl = "https://edu.hicomputing.huawei.com/AIeducationbase";

const notices = [
    {
        title: "重庆大学智能基座社团纳新报名表",
        date: "2026-03-28",
        tag: "DOCX",
        actionLabel: "立即下载",
        href: "/docs/recruitment-form.docx",
    },
    {
        title: "智能基座协会26春季纳新说明",
        date: "2026-03-28",
        tag: "DOCX",
        actionLabel: "立即下载",
        href: "/docs/recruitment-guide.docx",
    },
];
---

<Layout title="Waymaker 招新专区">
    <div class="min-h-screen bg-gray-50 py-12 px-8 flex flex-col">
        <div class="max-w-5xl mx-auto w-full flex-grow flex flex-col">
            <div class="mb-10 border-b pb-6">
                <h1 class="text-4xl font-extrabold text-gray-900">招新专区</h1>
                <p class="mt-4 text-xl text-gray-500">
                    Waymaker
                    智能基座社团面向全校同学长期开放，欢迎加入我们一起做技术分享、项目实践与赛事创新。
                </p>
            </div>

            <section
                class="mb-8 bg-white rounded-xl border border-[#D5EEEE] p-6 shadow-sm"
            >
                <div class="text-center">
                    <h2 class="text-2xl font-bold text-[#022F66]">常用入口</h2>
                    <p class="mt-2 text-[#475569] text-sm">
                        将原首页的四个常用入口迁移到招新页，便于一站式跳转。
                    </p>
                </div>

                <div class="mt-5 grid grid-cols-4 gap-4">
                    <a
                        href="/news"
                        class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-white text-[#022F66] border border-[#022F66] rounded-lg hover:bg-[#E6FAFA] transition-colors font-semibold"
                    >
                        查看全部动态 <span>→</span>
                    </a>
                    <a
                        href="/blogs"
                        class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-white text-[#022F66] border border-[#022F66] rounded-lg hover:bg-[#E6FAFA] transition-colors font-semibold"
                    >
                        查看全部博客 <span>→</span>
                    </a>
                    <a
                        href="/members"
                        class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-white text-[#022F66] border border-[#022F66] rounded-lg hover:bg-[#E6FAFA] transition-colors font-semibold"
                    >
                        成员风采 <span>→</span>
                    </a>
                    <a
                        href="/recruitment"
                        aria-current="page"
                        class="inline-flex items-center justify-center gap-2 px-4 py-3 bg-[#05C9C9] text-white rounded-lg hover:bg-[#03A8A8] transition-colors font-semibold"
                    >
                        加入我们 <span>→</span>
                    </a>
                </div>
            </section>

            <div class="grid grid-cols-2 gap-8 flex-grow content-start">
                <section
                    class="bg-white rounded-xl border border-[#D5EEEE] p-6 shadow-sm"
                >
                    <h2 class="text-2xl font-bold text-[#022F66]">社团官Q</h2>
                    <p class="mt-2 text-[#475569] text-sm leading-6">
                        扫码进入纳新咨询群，获取最新活动和答疑通知。
                    </p>

                    <div class="mt-6 flex justify-center">
                        <img
                            src="/QR%20code.jpg"
                            alt="社团纳新Q群二维码"
                            class="w-full max-w-md rounded-lg border border-[#D5EEEE] shadow"
                        />
                    </div>
                </section>

                <div class="space-y-6">
                    <DownloadFileList
                        title="资料下载"
                        description="后续招新手册、通知附件都会统一放在这里。"
                        helperText="新增文件时，沿用同一条目结构：标签 + 标题 + 更新时间 + 操作。"
                        items={notices}
                    />

                    <section
                        class="bg-white rounded-xl border border-[#D5EEEE] p-6 shadow-sm"
                    >
                        <h2 class="text-2xl font-bold text-[#022F66]">
                            成员认证入口
                        </h2>
                        <p class="mt-2 text-[#475569] text-sm leading-6">
                            统一跳转至鲲鹏与昇腾教育科研平台完成成员认证。
                        </p>
                        <div class="mt-5">
                            <a
                                href={authUrl}
                                target="_blank"
                                rel="noreferrer"
                                class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#05C9C9] text-white font-semibold hover:bg-[#03A8A8] transition-colors"
                            >
                                前往认证平台 <span>↗</span>
                            </a>
                        </div>
                    </section>
                </div>
            </div>

            <div class="mt-12">
                <a
                    href="/"
                    class="text-[#022F66] hover:text-[#011D3F] font-medium text-lg"
                    >← 返回首页</a
                >
            </div>
        </div>
    </div>
</Layout>
